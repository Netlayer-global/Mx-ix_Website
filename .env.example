# ============================================
# MX-IX Environment Variables (root reference)
# Copy relevant sections into backend/.env and frontend/.env
# ============================================

# ---------- BACKEND (backend/.env) ----------
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/mx-ix-admin
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@mx-ix.com
ADMIN_PASSWORD=change-this-strong-password
FRONTEND_URL=http://localhost:5173
GRAFANA_URL=
GRAFANA_API_KEY=
ZABBIX_URL=
ZABBIX_API_TOKEN=

# ---------- FRONTEND (frontend/.env) ----------
# Dev only. In production the app calls /api on the same origin.
VITE_API_URL=http://localhost:5000/api
